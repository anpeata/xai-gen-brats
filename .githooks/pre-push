#!/usr/bin/env sh

# Block pushes containing blobs larger than 5 MB.
MAX_SIZE=$((5 * 1024 * 1024))
NULL_SHA="0000000000000000000000000000000000000000"

TMP_ALL=$(mktemp)
TMP_SORTED=$(mktemp)

cleanup() {
  rm -f "$TMP_ALL" "$TMP_SORTED"
}

trap cleanup EXIT

while read -r local_ref local_sha remote_ref remote_sha

do
  [ "$local_sha" = "$NULL_SHA" ] && continue

  if [ "$remote_sha" = "$NULL_SHA" ]; then
    RANGE="$local_sha"
  else
    RANGE="$remote_sha..$local_sha"
  fi

  git rev-list --objects "$RANGE" >> "$TMP_ALL"
done

sort -u "$TMP_ALL" > "$TMP_SORTED"

FAILED=0
while IFS=' ' read -r oid path

do
  [ -z "$path" ] && continue

  TYPE=$(git cat-file -t "$oid" 2>/dev/null)
  [ "$TYPE" != "blob" ] && continue

  SIZE=$(git cat-file -s "$oid" 2>/dev/null)
  [ -z "$SIZE" ] && continue

  if [ "$SIZE" -gt "$MAX_SIZE" ]; then
    echo "ERROR: push blocked by file size policy (>5MB)."
    echo "  File: $path"
    echo "  Size: $SIZE bytes"
    FAILED=1
  fi
done < "$TMP_SORTED"

if [ "$FAILED" -ne 0 ]; then
  echo "Use external storage/LFS and keep git-tracked files at or below 5MB."
  exit 1
fi

exit 0
